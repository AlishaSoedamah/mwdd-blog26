---
import BaseHead from '../components/BaseHead.astro';
import ContextMenu from '../components/ContextMenu.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Folder from '../components/Folder.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="blog" description="blog" />
	</head>
	<body>
		<ContextMenu/>
		<Header/>
		<main>
			<div class="hero">
				<div class="deco"></div>
				<h1 class="post-title">Weekly Nerds</h1>
				<p>Mijn collectie van blogs van de sprekers voor de Minor Web Design & Development (MWDD)</p>
			</div>
			<ul>
				<Folder url="/blog/kilian" name="Kilian" session="00" side="odd"/>
				<Folder url="/blog/ppk" name="PPK" session="01" side="middle"/>
				<Folder url="/blog/nils" name="Nils" session="02" side="even"/>
				<Folder url="/blog/robbert" name="Robbert" session="03" side="odd"/>
				<Folder url="/blog/rosa" name="Rosa" session="04" side="middle"/>
				<Folder url="/blog/johan" name="Johan" session="05" side="odd"/>
				<Folder url="/blog/smash1" name="Smashing" session="dag 1" side="middle"/>
				<Folder url="/blog/smash2" name="Smashing" session="dag 2" side="even"/>
				<Folder url="/blog/hans" name="Hans" session="06" side="odd" />
				<Folder url="/blog/q42" name="Q42" session="07" side="middle"/>
				<Folder url="/blog/voorhoede" name="Voorhoede" session="08" side="odd"/>
				<Folder url="/blog/twyw1" name="TWYW" session="dag 1" side="even"/>
				<Folder url="/blog/twyw2" name="TWYW" session="dag 2" side="middle"/>
				<Folder url="/blog/cssday1" name="CSS Day" session="dag 1" side="even"/>
				<Folder url="/blog/cssday2" name="CSS Day" session="dag 2" side="odd"/>
			</ul>
		</main>
		<Footer/>
	</body>
</html>
<style>
	main {
		align-items: center;
		padding-inline: 20px;
	}

	ul {
		background: var(--folder-color);
		display: flex;
		flex-direction: column;
		outline: 1px solid var(--off-black);
		padding: 75px 25px 40px 25px;
		width: min(1000px, 100%);
	}

	.deco {
		width: 15px;
		aspect-ratio: 1;
		box-shadow:
		60px 0 red,
		15px 0 green,
		30px 0 rgb(105, 41, 255),
		45px 0 blue;
		animation: --color-boxes;  
		animation-duration: 1s;
		animation-iteration-count: infinite;
		animation-timing-function: steps(2);
	}

	@keyframes moveUp {
		0% {
			margin-top: -25px;
		}
		100% {
			margin-top: 0;
		}
	}
</style>