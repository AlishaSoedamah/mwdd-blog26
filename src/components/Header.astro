<header>
	<nav>
		<ul>
			<li id="timeDesktop"></li>
			<li>
				<label>
					⏾
				<input type="radio" name="contrast" value="highcontrast">
				</label>
			</li>
			<li>
				<label>
					☀
					<input type="radio" name="contrast" value="lowcontrast">
				</label>
			</li>
			<li id="battery">
				<span></span>
				<p id="title"></p>
			</li>
		</ul>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--off-black);
		nav {
			padding-inline: 10px;
			ul {
				margin: 0;
				padding: 0;
				display: flex;
				justify-content: space-between;
				align-items: center;
				list-style: none;
				li {
					color: var(--off-black);
				}
			}
		}
	}

	label {
		font-family: Arial, Helvetica, sans-serif;
		font-size: 25px;
		color: var(--off-black);
		&:hover {
			cursor: pointer;
		}
		input {
			display: none;
		}
	}

	#title {
		text-align: right;
	}

	#battery {
		display: relative;
		&::before {
			content: "";
			position: absolute;
			right: 60px;
			top: 14px;
			width: 20px;
			height: 10px;
			outline: 1px solid var(--off-black);
		}
		&::after {
			content: "";
			position: absolute;
			right: 65px;
			top: 14px;
			width: 15px;
			height: 10px;
			background: var(--off-black);
		}
	}

	span {
		position: absolute;
		right: 57px;
		top: 16px;
		width: 3px;
		height: 6px;
		background: var(--bg);
		border-right: var(--off-black) 1px solid;
		border-top: var(--off-black) 1px solid;
		border-bottom: var(--off-black) 1px solid;
	}
</style>

<script>
	//battery lvl - https://www.youtube.com/watch?v=x1B07Z3vYO4
	document.addEventListener("DOMContentLoaded", function() {
  		navigator.getBattery().then(function(battery) {
    		var level = battery.level;
    		document.getElementById("title").innerHTML = (level * 100) + "%";
    		document.getElementById("battery").style.backgroundPosition = (level * 100) + "%";
  		});
	});

	//get time of day
	var timeDesk = document.getElementById('timeDesktop');

	function time() {
	var d = new Date();
	var m = d.getMinutes();
	var h = d.getHours();
	timeDesk.textContent = 
		("0" + h).substr(-2) + ":" + ("0" + m).substr(-2);
	}

	setInterval(time, 1000);

		const inputs = document.querySelectorAll('[name="contrast"]');

	//theme switch
	const allInputs = document.querySelectorAll('[name="contrast"]');

	allInputs.forEach(input => {
	input.addEventListener('change', (e) => {
		const isHigh = e.target.value === 'highcontrast';

		if (isHigh) {
		document.documentElement.classList.add('high-contrast');
		localStorage.setItem('theme', 'highcontrast');
		} else {
		document.documentElement.classList.remove('high-contrast');
		localStorage.removeItem('theme');
		}

		// sync all inputs to match
		allInputs.forEach(i => {
		i.checked = i.value === (isHigh ? 'highcontrast' : 'lowcontrast');
		});
	});
	});

	// set initial state on load
	const saved = localStorage.getItem('theme');
	allInputs.forEach(i => {
	i.checked = i.value === (saved ?? 'lowcontrast');
	});
	if (saved === 'highcontrast') {
	document.documentElement.classList.add('high-contrast');
	}
</script>