<header>
	<nav>
		<ul>
			<li id="timeDesktop"></li>
			<li id="battery">Battery level:
				<p id="title"></p>
			</li>
		</ul>
		<label>
			Hoog contrast
			<input type="checkbox" name="hoogcontrast" value="highcontrast">
		</label>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--off-black);
		nav {
			padding-inline: 10px;
			ul {
				margin: 0;
				padding: 0;
				display: flex;
				justify-content: space-between;
				align-items: end;
				list-style: none;
				li {
					color: var(--off-black);
				}
			}
		}
	}

	label {
		color: var(--off-black);
	}

	#title {
		text-align: right;
	}
</style>

<script>
	//battery lvl - https://www.youtube.com/watch?v=x1B07Z3vYO4
	document.addEventListener("DOMContentLoaded", function() {
  		navigator.getBattery().then(function(battery) {
    		var level = battery.level;
    		document.getElementById("title").innerHTML = (level * 100) + "%";
    		document.getElementById("battery").style.backgroundPosition = (level * 100) + "%";
  		});
	});

	//localStorage highcontrast - 
    const input = document.querySelector('[value="highcontrast"]');

    if (localStorage.getItem('theme') === 'highcontrast') {
        input.checked = true;
    }

    input.addEventListener('change', () => {
        if (input.checked) {
            document.documentElement.classList.add('high-contrast');
            localStorage.setItem('theme', 'highcontrast');
        } else {
            document.documentElement.classList.remove('high-contrast');
            localStorage.removeItem('theme');
        }
    });

    if (localStorage.getItem('theme') === 'highcontrast') {
        document.documentElement.classList.add('high-contrast');
    }

	//get time of day
	var timeDesk = document.getElementById('timeDesktop');

	function time() {
	var d = new Date();
	var m = d.getMinutes();
	var h = d.getHours();
	timeDesk.textContent = 
		("0" + h).substr(-2) + ":" + ("0" + m).substr(-2);
	}

	setInterval(time, 1000);

</script>